# Reclaim AI Express backend — AI provider keys
# Copy to `.env` and fill in real values before `npm run dev`.
# Never commit `.env`.

# Fallback Gemini key (all AI routes).
# Clients may also send X-Gemini-Key to override per request.
GEMINI_API_KEY=

# Optional model override (default shown)
# GEMINI_MODEL=gemini-3.5-flash

# Server
PORT=4000
# Comma-separated origins allowed (useful when Next picks 3001)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
